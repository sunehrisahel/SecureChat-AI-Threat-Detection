# Optional — require Bearer token on POST /analyze
# DETECTOR_API_KEY=your-detector-key

# Optional — require Bearer token on GET /logs and /analytics
# ADMIN_API_KEY=your-admin-key

# Optional — require Bearer token on POST /suggest-fix
# RED_TEAM_API_KEY=your-red-team-key

# Rate limiting for /analyze
# RATE_LIMIT_ANALYZE=60
# RATE_LIMIT_WINDOW_SECONDS=60

# CORS (comma-separated origins)
# ALLOWED_ORIGINS=http://localhost:3000,https://your-chatbot.vercel.app
